# ═══════════════════════════════════════════════════════════
# Egadisailing Platform V2 — Environment variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill the required values. Every var is validated at boot
# by src/lib/env.ts (zod schema). Missing/invalid values fail-fast.

# ───── Node ─────
NODE_ENV=development
# Optional: trace | debug | info | warn | error | fatal (default: debug in dev, info in prod)
# LOG_LEVEL=debug

# ───── Database ─────
POSTGRES_USER=egadisailing
POSTGRES_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND
POSTGRES_DB=egadisailing
DATABASE_URL=postgresql://egadisailing:CHANGE_ME_USE_OPENSSL_RAND@127.0.0.1:5432/egadisailing

# ───── Redis ─────
REDIS_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND
REDIS_URL=redis://:CHANGE_ME_USE_OPENSSL_RAND@127.0.0.1:6379

# ───── NextAuth ─────
# Required. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_ME_WITH_OPENSSL_RAND_BASE64_32
NEXTAUTH_URL=http://localhost:3000

# ───── Seed admin ─────
# Required in production. Optional in dev (auto-generated if missing). Min 12 chars.
SEED_ADMIN_PASSWORD=

# ───── App ─────
APP_URL=http://localhost:3000
APP_LOCALES_DEFAULT=it

# ───── Stripe ─────
# Use TEST keys (sk_test_ / pk_test_) in dev, LIVE only in production.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# ───── Brevo (email) ─────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@egadisailing.com
BREVO_SENDER_NAME=Egadisailing

# ───── Cloudflare Turnstile ─────
# Dummy keys from Cloudflare that always pass (dev only). Replace in prod.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ───── Cron ─────
# Shared secret used to authenticate internal scheduler → /api/cron/* calls.
# Production: must be >= 32 chars, NOT the default string.
CRON_SECRET=dev-cron-please-change

# ───── Database pool ─────
# Max Prisma connections. Default 20 (suitable for up to 2 app replicas).
# DATABASE_POOL_MAX=20

# ═══════════════════════════════════════════════════════════
# Plan 3 — Bokun integration
# ═══════════════════════════════════════════════════════════
# Usa api.bokuntest.com per test/dev, api.bokun.io per prod.
BOKUN_API_URL=https://api.bokuntest.com
BOKUN_VENDOR_ID=
BOKUN_ACCESS_KEY=
BOKUN_SECRET_KEY=
BOKUN_WEBHOOK_SECRET=
# Markup su prezzi sito prima di pusharli a Bokun (1.15 = +15%)
BOKUN_PRICE_MARKUP=1.15

# ═══════════════════════════════════════════════════════════
# Plan 4 — Charter platforms (future)
# ═══════════════════════════════════════════════════════════
# Boataround API
# BOATAROUND_API_TOKEN=
# BOATAROUND_WEBHOOK_SECRET=

# IMAP for SamBoat/Click&Boat/Nautal email parsing
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=bookings@egadisailing.com
# IMAP_PASSWORD=

# ═══════════════════════════════════════════════════════════
# Plan 6 — Weather + observability (future)
# ═══════════════════════════════════════════════════════════
# Open-Meteo is free and requires no API key
# STORMGLASS_API_KEY=   # fallback provider, freemium

# Observability
# SENTRY_DSN=
# APP_VERSION=  # git sha, injected at build
