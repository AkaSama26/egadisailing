generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════
// SISTEMA
// ═══════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs      AuditLog[]
  // R26-A2-5/A2-7: inverse relations per FK aggiunti in migration
  // 20260421180000_r26_schema_hardening (onDelete: SetNull).
  bookingNotes   BookingNote[] @relation("BookingNoteAuthor")
  resolvedAlerts ManualAlert[] @relation("ManualAlertResolver")
  // Priority Override System (Fase 1 Trimarano) — tutte le richieste
  // decise da questo admin. FK onDelete: SetNull preserva audit storico.
  overrideDecisions OverrideRequest[]
  changeRequestDecisions BookingChangeRequest[] @relation("BookingChangeRequestDecision")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  timestamp DateTime @default(now())

  // R19-REG-MEDIA-1 NOTE: FK ha `ON DELETE SET NULL` nel DB dal migration
  // iniziale 20260418080924_v2_platform_foundation. Il `onDelete: SetNull`
  // esplicito qui matcha la realta' DB (nessun drift). Admin user delete
  // in futuro preservera' audit trail con userId null.
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId, timestamp])
  @@index([timestamp])
}

// ═══════════════════════════════════════════════════════════
// CATALOGO
// ═══════════════════════════════════════════════════════════

model Boat {
  id          String   @id
  name        String
  type        String
  description String
  length      Float?
  year        Int?
  cabins      Int?
  engineHp    Int?
  amenities   Json
  images      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services         Service[]
  availability     BoatAvailability[]
  bookings         Booking[]
}

enum PaymentSchedule {
  FULL
  DEPOSIT_BALANCE
}

enum DurationType {
  FULL_DAY
  HALF_DAY_MORNING
  HALF_DAY_AFTERNOON
  MULTI_DAY
  WEEK
}

model Service {
  id                       String          @id
  name                     String
  type                     String
  boatId                   String
  durationType             DurationType
  durationHours            Int
  capacityMax              Int
  minPaying                Int?
  defaultPaymentSchedule   PaymentSchedule @default(FULL)
  defaultDepositPercentage Int?
  priority                 Int             @default(5)
  pricingUnit              String          @default("PER_PERSON")
  bokunProductId           String?         @unique
  active                   Boolean         @default(true)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  boat            Boat             @relation(fields: [boatId], references: [id])
  bookings        Booking[]
  pricingPeriods  PricingPeriod[]
  servicePrices   ServicePrice[]
  hotDayOverrides HotDayOverride[]
}

// ═══════════════════════════════════════════════════════════
// PREZZI
// ═══════════════════════════════════════════════════════════

model Season {
  id          String   @id @default(cuid())
  year        Int
  key         String
  label       String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  priceBucket String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, key])
  @@index([year, startDate, endDate])
  @@index([year, priceBucket])
}

model ServicePrice {
  id           String   @id @default(cuid())
  serviceId    String
  year         Int
  priceBucket  String?
  durationDays Int?
  amount       Decimal  @db.Decimal(10, 2)
  pricingUnit  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId, year, priceBucket, durationDays])
  @@index([year, priceBucket])
}

model PricingPeriod {
  id             String   @id @default(cuid())
  serviceId      String
  label          String
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  pricePerPerson Decimal  @db.Decimal(10, 2)
  year           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId, startDate, endDate])
}

model HotDayRule {
  id             String   @id @default(cuid())
  name           String
  dateRangeStart DateTime @db.Date
  dateRangeEnd   DateTime @db.Date
  weekdays       Int[]
  multiplier     Decimal  @db.Decimal(4, 3)
  roundTo        Int      @default(10)
  priority       Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dateRangeStart, dateRangeEnd, active])
}

model HotDayOverride {
  id            String   @id @default(cuid())
  date          DateTime @db.Date
  serviceId     String?
  multiplier    Decimal? @db.Decimal(4, 3)
  absolutePrice Decimal? @db.Decimal(10, 2)
  roundTo       Int      @default(10)
  note          String?
  createdBy     String
  createdAt     DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id])

  @@unique([date, serviceId])
}

model BokunPriceSync {
  id                   String    @id @default(cuid())
  hotDayRuleId         String?
  bokunExperienceId    String
  bokunPriceOverrideId String?
  date                 DateTime  @db.Date
  amount               Decimal   @db.Decimal(10, 2)
  status               String
  syncedAt             DateTime?
  lastError            String?
  createdAt            DateTime  @default(now())

  // R28-CRIT-6: unique su (experienceId, date) per permettere upsert
  // idempotent dal pricing worker — retry BullMQ / duplicate-enqueue
  // non duplicano piu' la riga (audit fiscale pulito).
  @@unique([bokunExperienceId, date])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════
// DISPONIBILITA E SYNC
// ═══════════════════════════════════════════════════════════

enum AvailabilityStatus {
  AVAILABLE
  BLOCKED
  PARTIALLY_BOOKED
}

model BoatAvailability {
  id                String             @id @default(cuid())
  boatId            String
  date              DateTime           @db.Date
  status            AvailabilityStatus @default(AVAILABLE)
  lockedByBookingId String?
  lastSyncedSource  String?
  lastSyncedAt      DateTime?
  updatedAt         DateTime           @updatedAt
  createdAt         DateTime           @default(now())

  boat Boat @relation(fields: [boatId], references: [id])
  // R26-P4: FK onDelete SetNull. Orphan pointer prima era possibile
  // (lockedByBookingId → Booking.id senza vincolo). Ora hard-delete
  // Booking libera il lock automatic.
  lockedByBooking Booking? @relation("LockedByBooking", fields: [lockedByBookingId], references: [id], onDelete: SetNull)

  @@unique([boatId, date])
  @@index([status])
  @@index([date])
}

// Note: `SyncQueue` + enum `SyncStatus` erano il vecchio job model V1,
// sostituito da BullMQ (Plan 1/Round 2). Droppato in `round11_cleanup`.

model ChannelSyncStatus {
  channel      String    @id
  lastSyncAt   DateTime?
  lastError    String?
  healthStatus String    @default("GREEN")
  updatedAt    DateTime  @updatedAt
}

// ═══════════════════════════════════════════════════════════
// CLIENTI
// ═══════════════════════════════════════════════════════════

model Customer {
  id          String   @id @default(cuid())
  email       String   @unique
  firstName   String
  lastName    String
  phone       String?
  nationality String?
  language    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings        Booking[]
  emailOutboxEntries EmailOutbox[]
  // R26-A2-4: FK inverse (onDelete: SetNull in migration).
  consentRecords  ConsentRecord[]
}

// ═══════════════════════════════════════════════════════════
// PRENOTAZIONI
// ═══════════════════════════════════════════════════════════

enum BookingSource {
  DIRECT
  BOKUN
  BOATAROUND
  SAMBOAT
  CLICKANDBOAT
  NAUTAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

model Booking {
  id               String        @id @default(cuid())
  confirmationCode String        @unique
  source           BookingSource
  externalRef      String?
  customerId       String
  serviceId        String
  boatId           String
  startDate        DateTime      @db.Date
  endDate          DateTime      @db.Date
  cancellationPolicyAnchorDate DateTime? @db.Date
  numPeople        Int
  adultCount       Int           @default(0)
  childCount       Int           @default(0)
  freeChildSeatCount Int         @default(0)
  infantCount      Int           @default(0)
  totalPrice       Decimal       @db.Decimal(10, 2)
  currency         String        @default("EUR")
  status           BookingStatus @default(PENDING)
  exclusiveSlot    Boolean       @default(true)
  claimsAvailability Boolean     @default(true)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  weatherLastAlertedRisk String?
  weatherLastAlertedAt   DateTime?

  customer       Customer                      @relation(fields: [customerId], references: [id])
  service        Service                       @relation(fields: [serviceId], references: [id])
  boat           Boat                          @relation(fields: [boatId], references: [id])
  directBooking  DirectBooking?
  bokunBooking   BokunBooking?
  charterBooking CharterBooking?
  payments       Payment[]
  emailOutboxEntries EmailOutbox[]
  bookingNotes   BookingNote[]
  tripCrew       TripCrew[]
  // R26-A2-4/A2-7: inverse relations per FK aggiunti (onDelete: SetNull).
  consentRecords ConsentRecord[]
  manualAlerts   ManualAlert[]
  // R26-P4: inverse per BoatAvailability.lockedByBookingId FK.
  lockedCells    BoatAvailability[] @relation("LockedByBooking")
  // Priority Override System (Fase 1 Trimarano) — se questo booking e'
  // il "nuovo" in PENDING che vuole scavalcare conflict esistenti.
  overrideRequest OverrideRequest? @relation("NewBookingOverride")
  changeRequests BookingChangeRequest[]

  @@index([source, status])
  @@index([startDate])
  @@index([status, startDate])
  @@index([customerId])
  // R14-Area3: compound per overlap check in createPendingDirectBooking
  // (filter boatId + status IN + range startDate). Prima senza questo
  // index Postgres seq-scan su @@index([startDate]).
  @@index([boatId, status, startDate])
  // Per pending-gc query (status=PENDING AND source=DIRECT AND createdAt<cutoff).
  @@index([status, source, createdAt])
  @@index([exclusiveSlot, claimsAvailability, status])
  // R18-Prisma: reconciliation cron Bokun legge (source=BOKUN, externalRef=id)
  // — prima seq-scan su `source,status` compound con filter post.
  @@index([source, externalRef])
}

model EmailOutbox {
  id              String    @id @default(cuid())
  templateKey     String
  recipientEmail  String
  recipientName   String?
  replyToEmail    String?
  replyToName     String?
  subject         String
  htmlContent     String    @db.Text
  textContent     String?   @db.Text
  payload         Json
  status          String    @default("PENDING")
  attempts        Int       @default(0)
  lastError       String?   @db.Text
  brevoMessageId  String?
  idempotencyKey  String    @unique
  bookingId       String?
  customerId      String?
  nextAttemptAt   DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sentAt          DateTime?

  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([bookingId])
  @@index([customerId])
  @@index([templateKey, createdAt])
}

model DirectBooking {
  bookingId                 String          @id
  paymentSchedule           PaymentSchedule
  depositAmount             Decimal?        @db.Decimal(10, 2)
  balanceAmount             Decimal?        @db.Decimal(10, 2)
  stripePaymentIntentId     String?         @unique
  balanceReminderSentAt     DateTime?
  balancePaidAt             DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([paymentSchedule, balanceReminderSentAt, balancePaidAt])
}

enum BookingChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model BookingChangeRequest {
  id                 String                     @id @default(cuid())
  bookingId          String
  booking            Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  originalStartDate  DateTime                   @db.Date
  originalEndDate    DateTime                   @db.Date
  requestedStartDate DateTime                   @db.Date
  requestedEndDate   DateTime                   @db.Date
  customerNote       String?                    @db.Text

  status             BookingChangeRequestStatus @default(PENDING)
  adminNote          String?                    @db.Text
  decidedAt          DateTime?
  decidedByUserId    String?
  decidedBy          User?                      @relation("BookingChangeRequestDecision", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([bookingId, status])
  @@index([status, createdAt])
}

/// GDPR art. 7 — prova del consenso. Salvata al momento della creazione
/// del Booking con checkbox "accetto privacy + T&C" nel wizard.
///
/// Manteniamo IP + userAgent + `policyVersion` per tracciare quale copia
/// legale ha accettato il cliente. Non facciamo cascade su `onDelete`:
/// il ConsentRecord sopravvive alla cancellazione/anonymization del
/// Customer (audit fiscale + probatorio 10 anni art. 2220 c.c.).
model ConsentRecord {
  id              String   @id @default(cuid())
  customerId      String?
  bookingId       String?
  privacyAccepted Boolean  @default(false)
  termsAccepted   Boolean  @default(false)
  policyVersion   String
  acceptedAt      DateTime @default(now())
  ipAddress       String?
  userAgent       String?

  // R26-A2-4: FK onDelete SetNull — preserva row storica (GDPR audit
  // trail 10y) anche se Customer/Booking vengono hard-deleted in futuro.
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  booking  Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([bookingId])
  @@index([acceptedAt])
}

model BokunBooking {
  bookingId        String   @id
  bokunBookingId   String   @unique
  channelName      String
  commissionAmount Decimal? @db.Decimal(10, 2)
  netAmount        Decimal? @db.Decimal(10, 2)
  rawPayload       Json

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model CharterBooking {
  bookingId          String   @id
  platformName       String
  platformBookingRef String
  rawPayload         Json
  commissionAmount   Decimal? @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  @@unique([platformName, platformBookingRef])
}

// ═══════════════════════════════════════════════════════════
// PAGAMENTI
// ═══════════════════════════════════════════════════════════

enum PaymentType {
  DEPOSIT
  BALANCE
  FULL
  REFUND
}

enum PaymentMethod {
  STRIPE
  CASH
  BANK_TRANSFER
  EXTERNAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(cuid())
  bookingId      String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("EUR")
  type           PaymentType
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  stripeChargeId String?       @unique
  stripeRefundId String?       @unique
  note           String?
  createdAt      DateTime      @default(now())
  processedAt    DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, type])
  @@index([status])
}

/// Event-level idempotency per webhook Stripe: se vediamo lo stesso event.id
/// due volte (retry / replay attack entro tolerance), il secondo insert
/// fallisce con P2002 e il worker ritorna early.
model ProcessedStripeEvent {
  eventId     String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([eventType, processedAt])
  @@index([processedAt])
}

/// Event-level idempotency per webhook Bokun. Bokun non espone un event.id
/// canonico: usiamo hash(topic|bookingId|timestamp|signature) come chiave.
/// Se vediamo lo stesso event due volte (retry upstream, replay), il secondo
/// insert fallisce con P2002 e la route ritorna 200 early.
model ProcessedBokunEvent {
  eventId     String   @id
  topic       String
  processedAt DateTime @default(now())

  @@index([topic, processedAt])
  @@index([processedAt])
}

/// Event-level idempotency per webhook Boataround. `eventId =
/// sha256(type|bookingId|timestamp|signature)`. Stesso pattern di
/// `ProcessedBokunEvent` / `ProcessedStripeEvent` per dedup replay.
model ProcessedBoataroundEvent {
  eventId     String   @id
  eventType   String
  processedAt DateTime @default(now())

  @@index([eventType, processedAt])
  @@index([processedAt])
}

/// Dedup per email processate dal cron charter (Plan 4). Key = sha256
/// dell'header `Message-ID` (o fallback quando mancante). Retention 90g.
model ProcessedCharterEmail {
  messageHash String   @id
  platform    String?
  processedAt DateTime @default(now())

  @@index([processedAt])
}

/// Alert per azioni manuali sulle piattaforme charter che NON supportano
/// API (Click&Boat, Nautal). L'admin vede la lista in dashboard, fa
/// l'azione sul portale esterno, poi marca come risolto.
enum ManualAlertStatus {
  PENDING
  RESOLVED
  IGNORED
}

model ManualAlert {
  id             String            @id @default(cuid())
  channel        String            // CLICKANDBOAT | NAUTAL | CROSS_OTA_DOUBLE_BOOKING
  boatId         String
  date           DateTime          @db.Date
  action         String            // BLOCK | UNBLOCK | REVIEW
  status         ManualAlertStatus @default(PENDING)
  bookingId      String?
  notes          String?
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?
  resolvedByUserId String?

  // R26-A2-7: FK onDelete SetNull — alert rimane visibile storico anche
  // se booking/user cancellato, audit trail continuity.
  booking        Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  resolvedBy     User?    @relation("ManualAlertResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([channel, date])
}

// ═══════════════════════════════════════════════════════════
// PRIORITY OVERRIDE SYSTEM (Fase 1 Trimarano)
// ═══════════════════════════════════════════════════════════

model OverrideRequest {
  id                          String         @id @default(cuid())

  // Il booking NUOVO in PENDING che vuole scavalcare
  newBookingId                String         @unique
  newBooking                  Booking        @relation("NewBookingOverride", fields: [newBookingId], references: [id], onDelete: Cascade)

  // Booking ESISTENTI che verranno cancellati se approvato (array JSON)
  conflictingBookingIds       String[]

  // Sorgente canali dei conflicting booking (§9.1 spec).
  // Union di Booking.source dei conflict, es: ["DIRECT"], ["BOKUN"], ["DIRECT","BOKUN"]
  conflictSourceChannels      String[]

  // Revenue snapshot immutabile (audit + decisione admin)
  newBookingRevenue           Decimal        @db.Decimal(10, 2)
  conflictingRevenueTotal     Decimal        @db.Decimal(10, 2)

  // Lifecycle
  status                      OverrideStatus @default(PENDING)
  dropDeadAt                  DateTime       // = experience_date - 15d

  // Reconciliation cron §8.4 (post-approve OTA verification)
  reconcileCheckDue           DateTime?      // = now+1h quando admin approva con conflict OTA
  reconcileCheckedAt          DateTime?      // dedup cron — NULL = non ancora processato

  // Escalation reminder dedup (cron cron §8.1)
  reminderLevel               Int            @default(0)
  lastReminderSentAt          DateTime?

  // Decisione admin
  decidedAt                   DateTime?
  decidedByUserId             String?
  decidedByUser               User?          @relation(fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decisionNotes               String?        @db.Text

  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  @@index([status, dropDeadAt])
  @@index([status, createdAt])
  @@index([status, lastReminderSentAt])
  @@index([status, reconcileCheckDue])   // Per cron §8.4
}

enum OverrideStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  PENDING_RECONCILE_FAILED    // cron §8.4 ha rilevato upstream OTA still active
}

// ═══════════════════════════════════════════════════════════
// NOTES
// ═══════════════════════════════════════════════════════════

model BookingNote {
  id        String   @id @default(cuid())
  bookingId String
  note      String
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  // R26-A2-5: FK author onDelete SetNull — se User deletato in futuro,
  // BookingNote preservata per audit trail (authorId orphan fino a
  // retention, allineato pattern AuditLog.userId).
  author  User?   @relation("BookingNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

// ═══════════════════════════════════════════════════════════
// CREW
// ═══════════════════════════════════════════════════════════

enum CrewRole {
  SKIPPER
  CHEF
  HOSTESS
}

model CrewMember {
  id             String   @id @default(cuid())
  name           String
  role           CrewRole
  phone          String?
  email          String?  @unique
  dailyRate      Decimal? @db.Decimal(10, 2)
  certifications Json?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tripCrew TripCrew[]
}

// Note: `CrewAvailability` + enum `CrewAvailabilityStatus` droppati in
// round11_cleanup (zero app-code reference, feature mai esposta).

model TripCrew {
  id           String   @id @default(cuid())
  bookingId    String
  crewMemberId String
  role         CrewRole
  hoursWorked  Float?
  cost         Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  crewMember CrewMember @relation(fields: [crewMemberId], references: [id])

  @@unique([bookingId, crewMemberId])
}

// ═══════════════════════════════════════════════════════════
// METEO
// ═══════════════════════════════════════════════════════════

model WeatherForecastCache {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  locationKey String
  forecast    Json
  source      String
  fetchedAt   DateTime @default(now())

  @@unique([date, locationKey, source])
  @@index([fetchedAt])
}

// Note: enum `WeatherGuaranteeType` + model `WeatherGuaranteeApplication`
// droppati in round11_cleanup. Plan 6 reintrodurra' con UI admin se il
// cliente conferma la feature.

// ═══════════════════════════════════════════════════════════
// OTP E RATE LIMIT
// ═══════════════════════════════════════════════════════════

model BookingRecoveryOtp {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  attempts  Int       @default(0)
  ipAddress String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([email, expiresAt])
}

model BookingRecoverySession {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([email])
  @@index([expiresAt])
}

model RateLimitEntry {
  id           String    @id @default(cuid())
  identifier   String
  scope        String
  count        Int       @default(0)
  windowStart  DateTime
  windowEnd    DateTime
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([identifier, scope, windowEnd])
  @@index([blockedUntil])
}
